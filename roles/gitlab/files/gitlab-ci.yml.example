stages:
  - build
  - publish

variables:
  # Для локального GitLab без TLS. При HTTPS эту строку можно удалить.
  DOCKER_TLS_CERTDIR: ""
  DOCKER_HOST: tcp://docker:2375
  IMAGE_TAG: "$CI_REGISTRY_IMAGE:$CI_COMMIT_SHORT_SHA"

build_image:
  stage: build
  image: docker:27
  services:
    - name: docker:27-dind
      command: ["--insecure-registry=gitlab.diego.home:5050"]
  tags:
    - docker
  before_script:
    # CI_REGISTRY_USER и CI_REGISTRY_PASSWORD — временные учётные данные GitLab.
    - echo "$CI_REGISTRY_PASSWORD" | docker login "$CI_REGISTRY" -u "$CI_REGISTRY_USER" --password-stdin
  script:
    - docker build --pull -t "$IMAGE_TAG" -t "$CI_REGISTRY_IMAGE:latest" .
    - docker save "$IMAGE_TAG" "$CI_REGISTRY_IMAGE:latest" -o image.tar
  artifacts:
    paths: [image.tar]
    expire_in: 1 hour
  rules:
    - if: '$CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH'

publish_image:
  stage: publish
  image: docker:27
  services:
    - name: docker:27-dind
      command: ["--insecure-registry=gitlab.diego.home:5050"]
  tags:
    - docker
  needs:
    - job: build_image
      artifacts: true
  before_script:
    - echo "$CI_REGISTRY_PASSWORD" | docker login "$CI_REGISTRY" -u "$CI_REGISTRY_USER" --password-stdin
  script:
    - docker load -i image.tar
    - docker push "$IMAGE_TAG"
    - docker push "$CI_REGISTRY_IMAGE:latest"
  rules:
    - if: '$CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH'
