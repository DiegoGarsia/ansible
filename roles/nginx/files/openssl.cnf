[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
x509_extensions = req_ext

[dn]
CN = *.diego.home

[req_ext]
subjectAltName = @alt_names

[alt_names]
DNS.1 = *.diego.home
DNS.2 = diego.home
DNS.3 = nginx.diego.home
DNS.4 = proxy-docker.diego.home
DNS.5 = proxy-centos.diego.home
