# Generated by Ansible
# Role: firewall
# Host: {{ inventory_hostname }}

*filter

:INPUT {{ firewall_default_input_policy }} [0:0]
:FORWARD {{ firewall_default_forward_policy }} [0:0]
:OUTPUT {{ firewall_default_output_policy }} [0:0]

#
# Loopback
#
-A INPUT -i lo -j ACCEPT

#
# Established and related connections
#
-A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

{% for service_name, service in firewall_services | dictsort %}
{% if service.enabled | default(true) %}

#
# {{ service_name }}
#
{% set sources = service.sources | default(local_networks | default([])) %}

{% if sources | length > 0 %}
{% for source in sources %}
{% for port in service.ports %}
-A INPUT -p {{ service.protocol }} -s {{ source }} --dport {{ port }} -j ACCEPT
{% endfor %}
{% endfor %}
{% else %}
{% for port in service.ports %}
-A INPUT -p {{ service.protocol }} --dport {{ port }} -j ACCEPT
{% endfor %}
{% endif %}

{% endif %}
{% endfor %}

COMMIT
