$TTL 86400

@ IN SOA {{ dns_server }}.{{ dns_domain }}. hostmaster.{{ dns_domain }}. (
    {{ '%Y%m%d01' | strftime }}
    3600
    1800
    604800
    86400
)

@ IN NS {{ dns_server }}.

