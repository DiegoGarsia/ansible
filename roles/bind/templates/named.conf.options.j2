options {

    directory "/var/cache/bind";

    recursion yes;

    allow-query {
        localhost;
        192.168.0.0/24;
    };

    forwarders {
{% for server in dns_forwarders %}
        {{ server }};
{% endfor %}
    };

    dnssec-validation auto;

    listen-on {
        any;
    };

    listen-on-v6 {
        none;
    };
};
